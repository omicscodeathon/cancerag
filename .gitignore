# Data directories (large files) - exclude everything
data/
logs/

# ESSENTIAL FILES FOR DEPLOYMENT - DO NOT IGNORE
# Allow specific model files needed for inference (ONLY these 4 files)
!results/
!results/models/
!results/models/random_forest.pkl
!results/models/xgboost.pkl
!results/models/lightgbm.pkl
!results/models/logistic_regression.pkl

# Explicitly ignore subdirectories and other large models
results/models/*/
results/models/*_ensemble.pkl
results/models/*_deep.pkl
results/models/extra_trees.pkl
results/models/gradient_boosting.pkl
results/models/stacking_*.pkl
results/models/voting_*.pkl

# Allow preprocessing artifacts needed for inference
!data/processed/
!data/processed/ml_preprocessed/
!data/processed/ml_preprocessed/*.pkl
!data/processed/ml_preprocessed/*.json

# Allow receptor structures for docking (ONLY selected high-yield receptors)
!data/processed/receptors_selected/
!data/processed/receptors_selected/*.pdb
!data/processed/receptors_selected/*.pdbqt
!data/processed/receptors_selected/*.txt
!data/processed/binding_sites.json

# Allow other processed data files
!data/processed/*.json
!data/processed/*.csv

# Results - exclude large files but keep essential summaries
# Exclude all results first
results/figures/
results/reports/docking_results/
results/reports/clustering_analysis/cluster_assignments.csv
# Keep essential result summaries
!results/reports/final_results_summary.md
!results/reports/training_results.json
!results/reports/model_comparison_summary.csv
!results/reports/clustering_analysis/clustering_results.json

